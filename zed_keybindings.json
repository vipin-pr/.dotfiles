{
  "buffer_font_weight": 500.0,
  "vim": {
    "highlight_on_yank_duration": 250,
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": true
  },
  "buffer_font_family": "JetBrains Mono",
  "terminal": {
    "font_family": "Ubuntu",
    "font_size": 14.0
  },
  "wsl_connections": [
    {
      "distro_name": "Ubuntu-22.04",
      "user": null,
      "projects": [
        {
          "paths": [
            "/home/vpr/devops"
          ]
        }
      ]
    }
  ],
  "proxy": "",
  "project_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "gutter": {
    "min_line_number_digits": 1
  },
  "relative_line_numbers": "enabled",
  "git": {
    "inline_blame": {
      "enabled": false
    },
    "enable_status": true,
    "enable_diff": false
  },
  "outline_panel": {
    "dock": "left",
    "git_status": true
  },
  "tabs": {
    "git_status": true
  },
  "scrollbar": {
    "git_diff": false
  },
  "git_panel": {
    "dock": "left",
    "button": true,
    "tree_view": false
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Material Icon Theme",
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "auto",
  },
  "file_types": {},
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "VSCode Dark Modern",
  },
}